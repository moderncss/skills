    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "postcss-lit": "^1.4.1",
    "stylelint": "^17.4.0",
    "stylelint-config-alphabetical-order": "^2.0.0",
    "stylelint-config-modern": "^0.1.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
